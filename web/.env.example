# ============================================================
# MosBot Dashboard — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================

# Base URL of MosBot API (including API version prefix).
# Examples:
#   http://localhost:3000/api/v1      (local dev)
#   https://api.example.com/api/v1   (production)
VITE_API_URL=http://localhost:3000/api/v1

# Request timeout in milliseconds (optional, default: 10000)
# VITE_API_TIMEOUT=10000

# App display name (optional)
VITE_APP_NAME=MosBot
