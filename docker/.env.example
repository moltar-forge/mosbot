# MosBot Full-Stack Test Harness — Environment Variables
#
# These are generated automatically by `make setup` (docker-setup.sh).
# Copy this file to .env only if you want to customize values manually.
# Running `make setup` without a .env will generate all secrets for you.

# ── OpenClaw ──────────────────────────────────────────────────
OPENCLAW_CONFIG_DIR=./openclaw-config
OPENCLAW_WORKSPACE_DIR=./openclaw-config/workspace
OPENCLAW_GATEWAY_TOKEN=generated-by-docker-setup

# ── MosBot ────────────────────────────────────────────────────
TIMEZONE=America/New_York
JWT_SECRET=generated-by-docker-setup
OPENCLAW_WORKSPACE_TOKEN=generated-by-docker-setup
BOOTSTRAP_OWNER_PASSWORD=generated-by-docker-setup

