# Dependencies
node_modules/

# Environment — never commit real env files
.env
.env.bak
.env.local
.env.*.local
.envrc

# K8s secrets (never commit actual secrets)
k8s/base/secret.yaml
k8s/overlays/*/secret.yaml

# Key material and certificates
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
*.jks
*id_rsa*
*id_ed25519*
*service-account*.json
*credentials*.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code — personal settings (team settings.json is committed, local overrides are not)
.claude/settings.local.json
.claude/projects/

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/

# Build
dist/
build/

# Local DB dumps
*.sql.gz
*.dump

# Docker test harness runtime files
docker/.env
docker/docker-compose.extra.yml
docker/docker-compose.sandbox.yml
docker/openclaw-config/*
!docker/openclaw-config/.gitkeep
